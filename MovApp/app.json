{
  "expo": {
    "name": "campus-parking",
    "slug": "campusparking",
    "description": "Campus Parking - Tu Espacio Tu Parqueo",
    "primaryColor": "#223577",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#223577"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.campusparking.campusparking",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#223577"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "mescude1",
    "plugins": [
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos so you can attach vehicle and insurance pictures."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "1f2fe410-51d9-443d-b026-855cfbb9c6b5"
      }
    }
  }
}
